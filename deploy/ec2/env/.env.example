# ChillFilm Production Environment Variables
# Copy to /opt/movie-service/.env and fill in actual values
# DO NOT commit this file with real values

COMPOSE_PROJECT_NAME=chillfilm

# ── Spring Boot ────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_DATABASE=chillfilm
MYSQL_USER=chillfilm_user
MYSQL_PASSWORD=CHANGE_ME
MYSQL_ROOT_PASSWORD=CHANGE_ME

SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/chillfilm?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=chillfilm_user
SPRING_DATASOURCE_PASSWORD=CHANGE_ME

JPA_DDL_AUTO=validate
DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=2

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_TO_A_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_ACCESS_TOKEN_EXPIRATION=3600000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# ── Frontend / CORS ───────────────────────────────────────────────────────────
FRONTEND_URL=https://chillfilm.io.vn

# ── RAG Service ───────────────────────────────────────────────────────────────
RAG_BASE_URL=http://rag-chatbot:8000
RAG_TIMEOUT_SECONDS=20

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=chillfilm_movies
QDRANT_API_KEY=

# ── RAG Chatbot (FastAPI) ─────────────────────────────────────────────────────
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

# Embedding model — PHẢI khớp với model đã dùng khi tạo Qdrant collection
# Chạy check_collection.py để xem vector dimension trước khi đặt model
EMBEDDING_MODEL=CHANGE_TO_CURRENT_COMPATIBLE_MODEL
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=16
HF_HOME=/app/.cache/huggingface
DEFAULT_TOP_K=10
MAX_TOP_K=30
QDRANT_TIMEOUT_SECONDS=10

# LLM (optional)
LLM_PROVIDER=none
GEMINI_API_KEY=

# Legacy MySQL for RAG (fallback retrieval)
DB_HOST=mysql
DB_PORT=3306
DB_USER=chillfilm_user
DB_PASSWORD=CHANGE_ME
DB_NAME=chillfilm

# ── AWS ───────────────────────────────────────────────────────────────────────
# Ưu tiên dùng IAM Role cho EC2 thay vì hardcode key
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=chillfilm-assets-data
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Java ──────────────────────────────────────────────────────────────────────
JAVA_OPTS=-XX:MaxRAMPercentage=70.0 -XX:InitialRAMPercentage=30.0

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
