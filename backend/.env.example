# Backend environment variables example
# Copy to .env and fill in actual values

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/chillfilm?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=chillfilm_user
SPRING_DATASOURCE_PASSWORD=CHANGE_ME

JPA_DDL_AUTO=validate
DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=2

JWT_SECRET=CHANGE_TO_A_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_ACCESS_TOKEN_EXPIRATION=3600000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

FRONTEND_URL=https://chillfilm.io.vn

RAG_BASE_URL=http://rag-chatbot:8000
RAG_TIMEOUT_SECONDS=20

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=chillfilm_movies

AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=chillfilm-assets-data
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

JAVA_OPTS=-XX:MaxRAMPercentage=70.0 -XX:InitialRAMPercentage=30.0
