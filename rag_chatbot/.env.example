# RAG Chatbot environment variables
# Copy to .env and fill in actual values

# App
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=chillfilm_movies
QDRANT_API_KEY=
QDRANT_TIMEOUT_SECONDS=10

# Embedding model
# IMPORTANT: Must match the model used when creating the Qdrant collection
# Run scripts/check_collection.py to verify vector dimension first
EMBEDDING_MODEL=
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=16
HF_HOME=/app/.cache/huggingface

# Retrieval
DEFAULT_TOP_K=10
MAX_TOP_K=30

# LLM (optional)
LLM_PROVIDER=none
GEMINI_API_KEY=

# Logging
LOG_LEVEL=INFO

# MySQL fallback (legacy retrieval when Qdrant unavailable)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=movie_streaming_web
