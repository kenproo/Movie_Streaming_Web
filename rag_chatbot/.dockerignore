# Docker build context exclusions for RAG chatbot
# Không copy những file nhạy cảm và không cần thiết vào image

# Python artifacts
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/

# Environment files (NEVER copy secrets into image)
.env
.env.*
!.env.example

# Logs
*.log
logs/

# Tests (không cần trong production image)
tests/

# Development tools
.git/
.gitignore
*.md

# IDE
.vscode/
.idea/
